{
  "name": "api-basic-social",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "dev": "NODE_ENV=dev nodemon src/server.js",
    "test": "mocha './test/**/*.test.js'",
    "coverage": "nyc --reporter=lcov --reporter=text mocha './test/**/*.test.js'",
    "start": "node src/server.js",
    "lint": "eslint",
    "build": "echo 'No build step required'",
    "migrations:run": "sequelize-cli db:migrate --env $NODE_ENV",
    "migrations:revert": "sequelize-cli db:migrate:undo --env $NODE_ENV",
    "migrations:delete": "sequelize-cli db:migrate:undo:all --env $NODE_ENV",
    "migration:generate": "sequelize-cli migration:generate --name",
    "seeder:generate": "sequelize-cli seed:generate --name",
    "seeders:all": "sequelize-cli db:seed:all --env $NODE_ENV",
    "seeder:run": "sequelize-cli db:seed --env $NODE_ENV --seed"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-jwt": "^8.5.1",
    "express-rate-limit": "^8.2.1",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.16.0",
    "pg": "^8.16.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.7"
  },
  "devDependencies": {
    "chai": "^6.2.2",
    "chai-as-promised": "^8.0.2",
    "chai-http": "^5.1.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "mocha": "^11.7.5",
    "nodemon": "^3.1.11",
    "nyc": "^17.1.0",
    "prettier": "^3.7.4",
    "sequelize-cli": "^6.6.5",
    "sinon": "^21.0.1",
    "supertest": "^7.2.2"
  },
  "nyc": {
    "reporter": [
      "text",
      "lcov"
    ],
    "report-dir": "./coverage",
    "exclude": [
      "test/**",
      "node_modules/**"
    ],
    "extension": [
      ".js"
    ]
  }
}
