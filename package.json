{
  "name": "api-basic-social",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "dev": "NODE_ENV=dev nodemon app.js",
    "test": "mocha './test/**/*.test.js'",
    "start": "node app.js",
    "lint": "eslint",
    "build": "echo 'No build step required'",
    "migration:generate": "sequelize-cli migration:generate --name",
    "migrations:run": "sequelize-cli db:migrate",
    "migrations:revert": "sequelize-cli db:migrate:undo",
    "migrations:delete": "sequelize-cli db:migrate:undo:all",
    "seeder:generate": "sequelize-cli seed:generate --name",
    "seeders:all": "sequelize-cli db:seed:all",
    "seeder:run": "sequelize-cli db:seed --seed"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
